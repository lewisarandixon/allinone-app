{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node --transpile-only src/scripts/seed.ts",
    "worker": "node --enable-source-maps ./src/jobs/worker.js",
    "queues:drain": "node --enable-source-maps ./src/scripts/queues-drain.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ci": "pnpm lint && pnpm -s build && pnpm -s test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@azure/msal-node": "^3.7.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@sentry/nextjs": "^10.5.0",
    "@stripe/stripe-js": "^7.8.0",
    "axios": "^1.11.0",
    "bullmq": "^5.57.0",
    "class-variance-authority": "^0.7.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "googleapis": "^156.0.0",
    "ioredis": "^5.7.0",
    "isomorphic-fetch": "^3.0.0",
    "lucide-react": "^0.539.0",
    "next": "15.4.6",
    "next-auth": "^4.24.11",
    "node-quickbooks": "^2.0.46",
    "openai": "^5.12.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "xero-node": "^13.0.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.54.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "playwright": "^1.54.2",
    "postcss": "^8.5.6",
    "prisma": "^6.14.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
